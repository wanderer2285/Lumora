// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for user roles
enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// Enum for enrollment status
enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

// Enum for progress status
enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(STUDENT)
  isActive  Boolean  @default(true)

  // Relations
  createdCourses Course[]     @relation("CourseCreator")
  enrollments    Enrollment[] @relation("StudentEnrollments")
  progress       Progress[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Course {
  id           String @id @default(cuid())
  title        String
  description  String @db.Text
  instructorId String
  instructor   User   @relation("CourseCreator", fields: [instructorId], references: [id], onDelete: Cascade)

  isPublished  Boolean @default(false)
  thumbnailUrl String?

  // Relations
  lessons     Lesson[]
  enrollments Enrollment[] @relation("CourseEnrollments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([isPublished])
  @@index([createdAt])
  @@index([title])
}

model Lesson {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  content  String  @db.Text
  position Int
  duration Int? // Duration in minutes
  videoUrl String?

  // Relations
  progress Progress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, position])
  @@index([courseId])
  @@index([position])
}

model Enrollment {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation("CourseEnrollments", fields: [courseId], references: [id], onDelete: Cascade)

  status   EnrollmentStatus @default(ACTIVE)
  progress Float            @default(0) // Percentage: 0-100

  // Relations
  progressRecords Progress[]

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
}

model Progress {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  status       ProgressStatus @default(NOT_STARTED)
  completedAt  DateTime?
  timeSpent    Int            @default(0) // Time spent in seconds
  lastPosition Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([lessonId])
  @@index([enrollmentId])
  @@index([status])
  @@index([completedAt])
}
